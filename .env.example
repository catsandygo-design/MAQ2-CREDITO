# Supabase / Backend de teste
# 1) Crie um projeto no Supabase
# 2) Copie Project URL e anon public key em Project Settings > API
# 3) Copie a service_role key somente para ambiente seguro do servidor/Vercel
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY

# Banco Postgres direto do Supabase
# Se a senha tiver caracteres especiais (@, #, ?, /, etc.), use URL encode.
DATABASE_URL=postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require
AUTO_CREATE_TABLES=false
STARTUP_DB_STRICT=false
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=10
APP_CORRETOR_USER=corretor
APP_CORRETOR_PASSWORD=CHANGE_ME_CORRETOR
APP_CCA_USER=cca
APP_CCA_PASSWORD=CHANGE_ME_CCA
APP_ANALISTA_USER=analista
APP_ANALISTA_PASSWORD=CHANGE_ME_ANALISTA
APP_ADMIN_USER=douglasadm
APP_ADMIN_PASSWORD=CHANGE_ME_ADMIN
APP_GESTOR_USER=gestor
APP_GESTOR_PASSWORD=CHANGE_ME_GESTOR
APP_GESTOR_CREDITO_USER=gestor_credito
APP_GESTOR_CREDITO_PASSWORD=CHANGE_ME_GESTOR_CREDITO
# Compatibilidade legada (fallback para CCA se APP_CCA_* nao estiver definido)
APP_LOGIN_USER=cca
APP_LOGIN_PASSWORD=CHANGE_ME_CCA
PASSWORD_HASH_ITERATIONS=200000
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SYMBOL=true
ALLOW_WEAK_SEED_PASSWORDS=false
ENABLE_LEGACY_DEMO_USERS=false
SESSION_TTL_SECONDS=43200
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_COOKIE_SECURE=true
FALL_RISK_DAYS=15
PII_ENCRYPTION_KEY=GENERATE_WITH_security_utils.generate_pii_encryption_key
