  "simulacao_financeira": {
    "entradas_obrigatorias": {
      "renda_bruta": {
        "tipo": "float",
        "minimo_exclusivo": 0
      },
      "valor_tabela": {
        "tipo": "float",
        "minimo_exclusivo": 0
      },
      "sobrepreco_vila": {
        "tipo": "float",
        "minimo_inclusivo": 0
      },
      "valor_obtido": {
        "tipo": "float",
        "minimo_inclusivo": 0
      },
      "parcela_caixa": {
        "tipo": "float",
        "minimo_inclusivo": 0
      },
      "preco_digitado_corretor": {
        "tipo": "float",
        "minimo_inclusivo": 0,
        "padrao": 0
      }
    },
    "politica_preco": {
      "formula_preco_base_politica": "max(valor_tabela, valor_obtido) + sobrepreco_vila",
      "formula_preco_final": "max(preco_base_politica, preco_digitado_corretor)",
      "bloqueios": [
        {
          "condicao": "preco_digitado_corretor > 0 e preco_digitado_corretor < preco_base_politica",
          "efeito": {
            "erro_politica": true,
            "mensagem": "Valor abaixo da politica comercial"
          }
        }
      ],
      "alerta_preco": {
        "condicao": "valor_obtido > valor_tabela",
        "valor_quando_verdadeiro": "Ajustado pelo Obtido",
        "valor_quando_falso": "Preco Base"
      }
    },
    "entrada_e_parcelamento": {
      "formula_entrada_liquida": "preco_final - valor_obtido",
      "juros_ao_mes": 0.01,
      "numero_maximo_meses": 80,
      "valor_minimo_parcela": 125.0,
      "regra": [
        "Se entrada_liquida <= 0, o plano fica 'A vista' e a parcela fica 0.",
        "Se entrada_liquida > 0, calcula PMT em ate 80 meses com juros de 1% ao mes.",
        "Se o PMT calculado ficar abaixo de R$ 125,00, a parcela e fixada em R$ 125,00 e o numero de meses e recalculado, limitado a 80."
      ],
      "formula_pmt": "pv * ((i * (1 + i)^n) / ((1 + i)^n - 1))"
    },
    "risco_e_garantidores": {
      "formula_exposicao_risco": "(valor_tabela - valor_obtido) / valor_tabela",
      "garantidores_necessarios": [
        {
          "condicao": "exposicao_risco > 0.06",
          "quantidade": 2
        },
        {
          "condicao": "exposicao_risco > 0.05 e exposicao_risco <= 0.06",
          "quantidade": 1
        },
        {
          "condicao": "exposicao_risco <= 0.05",
          "quantidade": 0
        }
      ]
    },
    "is_pos_chaves": {
      "formula": "(parcela_caixa + valor_parcela_entrada) / renda_bruta",
      "limite_referencia_percentual": 40.0,
      "faixas": [
        {
          "condicao": "is_pos_chaves < 0.35",
          "status_ia": "PERFIL_SEG_01",
          "bloqueio_critico": false,
          "motivo_auditoria": ""
        },
        {
          "condicao": "is_pos_chaves >= 0.35 e is_pos_chaves < 0.40",
          "status_ia": "PERFIL_DOU_02",
          "bloqueio_critico": false,
          "motivo_auditoria": "Atencao: Margem de seguranca reduzida. Possivel ganancia no preco ou baixa renda."
        },
        {
          "condicao": "is_pos_chaves >= 0.40",
          "status_ia": "PERFIL_CRI_03",
          "bloqueio_critico": true,
          "motivo_auditoria": "Renda insuficiente para suporte pos-chaves."
        }
      ]
    },
    "saida_principal": {
      "apresentacao_cliente": [
        "valor_imovel",
        "valor_obtido",
        "entrada_facilitada",
        "plano_pagamento",
        "valor_parcela"
      ],
      "leitura_executiva_corretor": [
        "status_ia",
        "risco_exposicao",
        "garantidores_necessarios",
        "is_pos_chaves",
        "is_limite",
        "bloqueio_critico",
        "motivo_auditoria",
        "alerta_preco"
      ]
    }
  },
  "frankstein_recomendacao": {
    "contexto": "Camada assistida que preserva a heuristica financeira e aplica ajuste suave de preco com base em probabilidade.",
    "features_modelo": [
      "renda_bruta",
      "valor_tabela",
      "sobrepreco_vila",
      "valor_obtido",
      "parcela_caixa",
      "preco_digitado_corretor",
      "exposicao",
      "is_pos_chaves"
    ],
    "probabilidade_padrao_sem_modelo": 0.62,
    "modelo_atual": {
      "tipo": "logistica_leve",
      "fonte_runtime": [
        "data/frankstein_model.json",
        "tabela frankstein_models"
      ],
      "observacao": "O treino atual nasce de amostras sinteticas para bootstrap, nao de feedback real validado."
    },
    "regras_runtime": [
      "Sempre executa primeiro o motor deterministico de simulacao.",
      "Se houver modelo carregado, a probabilidade de aceite vem do modelo; sem modelo, usa 0.62.",
      "Se houver bloqueio critico pela regra de IS >= 40%, adiciona sugestao de reduzir preco em aproximadamente 3% e limita a probabilidade a no maximo 0.40.",
      "O preco_frankstein final e calculado por: preco_heuristico * (0.97 + 0.06 * prob_aceite).",
      "A confianca retornada hoje espelha a propria probabilidade estimada."
    ],
    "persistencia_eventos": {
      "destino_preferencial": "tabela frankstein_events",
      "fallback": "arquivo local com lista JSON",
      "campos_registrados": [
        "input",
        "heuristica",
        "frankstein",
        "features",
        "user_agent",
        "client_host",
        "timestamp"
      ]
    }
  },
  "frankstein_operacional": {
    "perfis_aceitos": [
      "CLT",
      "AUTONOMO",
      "APOSENTADO",
      "OUTRO"
    ],
    "documentos_exigidos_por_perfil": {
      "todos_os_perfis": [
        "rg_cpf",
        "comprovante_residencia",
        "renda_informada"
      ],
      "perfil_clt": [
        "comprovante_renda",
        "fgts_validado"
      ]
    },
    "analise_valor": {
      "formula_cobertura_total": "garantido + cheque_moradia",
      "formula_diferenca": "cobertura_total - valor_venda",
      "regras": [
        {
          "condicao": "diferenca >= 0",
          "status_valor": "viavel",
          "faltante": 0.0,
          "mensagem": "A composicao financeira atende o valor da venda."
        },
        {
          "condicao": "diferenca < 0",
          "status_valor": "ajustar",
          "faltante": "abs(diferenca)",
          "mensagem": "Faltam R$ X para sustentar o valor da venda."
        }
      ]
    },
    "score_risco": {
      "escala": "0-1",
      "base": 0.1,
      "incrementos": [
        {
          "condicao": "faltante > 0",
          "incremento": 0.35
        },
        {
          "condicao": "qtd_problemas >= 1",
          "incremento": 0.2
        },
        {
          "condicao": "qtd_problemas >= 3",
          "incremento": 0.15
        },
        {
          "condicao": "perfil == CLT e fgts_validado == false",
          "incremento": 0.1
        },
        {
          "condicao": "renda_informada == null",
          "incremento": 0.1
        }
      ],
      "regra_pos_processamento": "resultado limitado entre 0.0 e 1.0 e arredondado em 2 casas",
      "classificacao": [
        {
          "condicao": "score >= 0.75",
          "valor": "alto_risco"
        },
        {
          "condicao": "score >= 0.40 e score < 0.75",
          "valor": "medio_risco"
        },
        {
          "condicao": "score < 0.40",
          "valor": "baixo_risco"
        }
      ]
    },
    "status_geral": {
      "valores_modelados": [
        "viavel",
        "ajustar",
        "bloquear"
      ],
      "valores_emitidos_atualmente": [
        "viavel",
        "ajustar"
      ],
      "regras": [
        {
          "condicao": "ha problema em comprovante_renda ou renda_informada",
          "retorno": "ajustar"
        },
        {
          "condicao": "faltante > 0",
          "retorno": "ajustar"
        },
        {
          "condicao": "nenhuma das regras acima",
          "retorno": "viavel"
        }
      ]
    },
    "decisoes_recomendadas": [
      {
        "condicao": "status_geral == viavel",
        "codigo": "AVANCAR",
        "titulo": "Avancar"
      },
      {
        "condicao": "faltante > 0 e ha campos_problema",
        "codigo": "AJUSTAR_VALOR_E_DOCUMENTACAO",
        "titulo": "Ajustar valor e documentacao"
      },
      {
        "condicao": "faltante > 0 e nao ha campos_problema",
        "codigo": "AJUSTAR_VALOR",
        "titulo": "Ajustar valor"
      },
      {
        "condicao": "sem faltante e com problema documental",
        "codigo": "AJUSTAR_DOCUMENTACAO",
        "titulo": "Ajustar documentacao"
      }
    ],
    "baloes_operacionais": [
      {
        "id": "bl_001",
        "gatilho": "faltante > 0",
        "tipo": "insight",
        "titulo": "Valor acima da aderencia"
      },
      {
        "id": "bl_002",
        "gatilho": "campo comprovante_renda em campos_problema",
        "tipo": "alerta",
        "titulo": "Renda nao comprovada"
      },
      {
        "id": "bl_003",
        "gatilho": "campo fgts_validado em campos_problema",
        "tipo": "alerta",
        "titulo": "FGTS nao validado"
      },
      {
        "id": "bl_004",
        "gatilho": "score.classificacao == alto_risco",
        "tipo": "acao",
        "titulo": "Proximo passo recomendado"
      },
      {
        "id": "bl_004",
        "gatilho": "score.classificacao diferente de alto_risco",
        "tipo": "decisao",
        "titulo": "Situacao controlada"
      }
    ],
    "metricas_operacionais": {
      "risco_pendencia": "limitar_entre_0_e_1(score + 0.05)",
      "risco_atraso_sla": "limitar_entre_0_e_1(score - 0.10)",
      "confianca_modelo": 0.81
    }
  },
