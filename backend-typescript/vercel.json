{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/v1/health", "destination": "/api/health" },
    { "source": "/api/v1/foguetinho/evaluate", "destination": "/api/foguetinho/evaluate" }
  ]
}
